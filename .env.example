# ---- Database ----
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/Cresto_clinic?appName=Cluster0

# ---- Auth (NextAuth) ----
# Generate a secret: `openssl rand -hex 32`
NEXTAUTH_SECRET=replace-with-random-32-byte-hex
NEXTAUTH_URL=http://localhost:3000

# Public origin for sitemap.xml, robots.txt and metadata canonical/OG URLs.
# Set to the real production domain on deploy (e.g. https://crestophysio.com).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Google Analytics 4 (optional) ----
# Set to your GA4 Measurement ID to enable analytics. Leave blank to disable.
NEXT_PUBLIC_GA_ID=

# ---- Admin bootstrap account ----
ADMIN_EMAIL=admin@crestophysio.com
ADMIN_PASSWORD=change-me

# ---- ImageKit (media CDN) ----
IMAGEKIT_PUBLIC_KEY=public_xxx
IMAGEKIT_PRIVATE_KEY=private_xxx
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_id/

# ---- Email (SMTP, e.g. Gmail app password) ----
EMAIL_SERVER_HOST=smtp.gmail.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=your@gmail.com
EMAIL_SERVER_PASSWORD=app-password
# IMPORTANT: When using Gmail SMTP, EMAIL_FROM MUST be the same gmail.com address
# as EMAIL_SERVER_USER. Gmail will override any other From address, causing
# "sent on behalf of" display and spam classification.
# If you want to send from a custom domain (e.g. info@crestophysio.com), use
# Resend (configured below) instead of Gmail SMTP.
EMAIL_FROM=your@gmail.com
# Friendly From display name shown in the inbox.
EMAIL_FROM_NAME=Cresto Physiotherapy Clinic
# Postal address shown in the email footer (legitimacy/deliverability signal).
CLINIC_ADDRESS=No.70/1, Benaka Plaza, Doddakammanahalli, Bannerghatta Road, Bengaluru, Karnataka 560076

# ---- Resend (recommended for inbox deliverability) ----
# When set, ALL mail is sent via Resend instead of Gmail SMTP. Resend signs with
# DKIM aligned to your verified domain — the real fix for spam placement.
# 1. Sign up at resend.com  2. Add + verify the domain crestophysio.com (paste
#    the DNS records Resend shows)  3. Create an API key  4. set both below.
# RESEND_FROM must be on the verified domain (a gmail.com from is rejected).
RESEND_API_KEY=
RESEND_FROM=Cresto Physiotherapy Clinic <noreply@crestophysio.com>

# ---- Upstash Redis (rate limiting) ----
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token
